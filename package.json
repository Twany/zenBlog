{
  "name": "twanyBlog",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "blog:draft": "python3 scripts/blog_draft.py",
    "blog:publish": "python3 scripts/blog_publish.py",
    "blog:validate": "python3 scripts/blog_validate.py",
    "og:generate": "node scripts/generate_og_images.mjs",
    "visual:qa": "node scripts/visual_qa.mjs",
    "visual:qa:update": "node scripts/visual_qa.mjs --update-baseline",
    "visual:qa:compare": "node scripts/visual_qa.mjs --fail-on-diff",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.13",
    "@astrojs/sitemap": "^3.4.2",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.16.6",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.13",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "playwright-core": "^1.61.1",
    "postcss": "^8.4.47",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
