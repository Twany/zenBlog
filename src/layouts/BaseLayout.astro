---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import TopographicHeader from '../components/TopographicHeader.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromPath, type Locale } from '../utils/i18n';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  lang?: Locale;
  image?: string;
  imageAlt?: string;
  canonical?: string;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    tags?: string[];
  };
}

const { title, description, type, lang, image, imageAlt, canonical, article } =
  Astro.props as Props;
const currentPath = Astro.url.pathname;
const resolvedLang = (lang ?? getLocaleFromPath(currentPath)) as Locale;
const analyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN;
const analyticsBeacon = analyticsToken
  ? JSON.stringify({ token: analyticsToken })
  : '';
---

<!doctype html>
<html lang={resolvedLang}>
  <head>
    <SeoHead
      title={title}
      description={description}
      type={type}
      lang={resolvedLang}
      pathname={currentPath}
      image={image}
      imageAlt={imageAlt}
      canonical={canonical}
      article={article}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-brand-cyan focus:text-white focus:px-4 focus:py-2 focus:rounded"
    >
      Skip to main content
    </a>
    <TopographicHeader lang={resolvedLang} currentPath={currentPath} />
    <main
      id="main-content"
      class="flex-grow pt-20 lg:pt-24 pb-16"
      tabindex="-1"
    >
      <slot />
    </main>
    <Footer lang={resolvedLang} />
    {
      analyticsToken ? (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={analyticsBeacon}
        />
      ) : null
    }
  </body>
</html>
