---
import type { GetStaticPathsOptions, Page } from "astro";
import { type CollectionEntry, getCollection } from "astro:content";
import Pagination from "../../components/Pagination.astro";
import { sortItemsByDateDesc } from "../../utils/helpers";
import MainLayout from "../../layouts/MainLayout.astro";
import getSiteConfig from "../../site.config";
import PostCardPreview from "../../components/PostCardPreview.astro";
import { defaultLang, type Lang } from "../../i18n/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const currentConfig = getSiteConfig(defaultLang);
  const blogs = (await getCollection("blogs"))
    .filter((post) => post.data.lang === defaultLang)
    .sort(sortItemsByDateDesc);
  return paginate(blogs, { pageSize: currentConfig.postsPerPage || 2 });
}

type Props = { page: Page<CollectionEntry<"blogs">>; lang?: Lang };

const { page, lang = defaultLang } = Astro.props as Props;
const siteConfig = getSiteConfig(lang);
const allPosts = page.data;
const pageTitle = `${siteConfig.title} | ${siteConfig.blog?.title ?? "Blog"}`;
---

<MainLayout activePage="blog" pageTitle={pageTitle} lang={lang}>
  <div class="page-content py-8 text-center">
    <h1 class="sigmar-ff">{siteConfig.blog?.title || "Blog"}</h1>
    {
      siteConfig.blog?.description && (
        <p class="font-light text-balance">{siteConfig.blog?.description}</p>
      )
    }

    <div
      class="flex flex-col text-left gap-8 mb-4 text-sm sm:text-base max-w-fit mx-auto"
    >
      {allPosts.map((post) => <PostCardPreview post={post} lang={lang} />)}
    </div>
    <Pagination page={page} class="mb-16 sm:mb-24" />
  </div>
</MainLayout>
