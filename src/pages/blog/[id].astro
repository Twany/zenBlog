---
import "../../styles/global.css";
import { Image } from "astro:assets";
import {
  sortItemsByDateDesc,
  createSlugFromTitle,
  withBase,
  getSlugFromId,
} from "../../utils/helpers";
import { type CollectionEntry, getCollection, render } from "astro:content";
import Button from "../../components/Button.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import ArrowLeft from "../../icons/ArrowLeft.astro";
import ArrowRight from "../../icons/ArrowRight.astro";
import getSiteConfig from "../../site.config";
import { defaultLang, type Lang } from "../../i18n/config";
import { localizePath } from "../../i18n/utils";

export async function getStaticPaths() {
  const posts = (await getCollection("blogs"))
    .filter((post) => post.data.lang === defaultLang)
    .sort(sortItemsByDateDesc);
  const postCount = posts.length;
  return posts.map((post, index) => ({
    params: { id: post.slug ?? getSlugFromId(post.id) },
    props: {
      post,
      prevPost: index + 1 !== postCount ? posts[index + 1] : null,
      nextPost: index !== 0 ? posts[index - 1] : null,
    },
  }));
}

type Props = {
  post: CollectionEntry<"blogs">;
  prevPost: CollectionEntry<"blogs"> | null;
  nextPost: CollectionEntry<"blogs"> | null;
  lang?: Lang;
};

const { post, prevPost, nextPost, lang = defaultLang } = Astro.props as Props;
const siteConfig = getSiteConfig(lang);
const { title, pubDate, author, tags = [], image } = post.data;
const { Content } = await render(post);
const pageTitle = `${siteConfig.title} | ${title}`;
const taggedLabel = siteConfig.blog?.taggedLabel || "Tagged";
const backToListLabel = siteConfig.blog?.backToListLabel || "Back to All Stories";
const nextPostLabel = siteConfig.blog?.nextPostLabel || "Next Post";
const getPostSlug = (entry: CollectionEntry<"blogs"> | null) =>
  entry ? entry.slug ?? getSlugFromId(entry.id) : "";
const nextSlug = getPostSlug(nextPost);
---

<MainLayout pageTitle={pageTitle} activePage="blog" lang={lang}>
  <div class="page-content">
    <h1 class="sigmar-ff text-center text-balance">{title}</h1>
    <p class="leading-8 text-center kanit-regular text-balance text-xs">
      by 🧑‍🚀 <span class="kanit-bold">{author}</span> on <span class="kanit-bold"
        >{new Date(pubDate).toDateString()}</span
      >
    </p>
    {
      image && image.url && (
        <Image class="mb-8 my-6" src={image?.url} alt={image?.alt || ""} />
      )
    }
    <div class="font-light text-left">
      <Content />
    </div>
    <p class="kanit-regular text-center text-balance text-xs">
      {taggedLabel}: {
        tags.map((tag) => (
          <Button
            class="px-4! m-2"
            href={withBase(localizePath(`/tags/${createSlugFromTitle(tag)}`, lang))}
          >
            {tag}
          </Button>
        ))
      }
    </p>
    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4 my-8"
    >
      <Button class="back-link" href={withBase(localizePath("/blog", lang))}>
        <ArrowLeft class="w-5 h-5 fill-current mr-4" /> {backToListLabel}
      </Button>
      {
        (prevPost || nextPost) && nextPost && nextSlug && (
          <Button
            class="back-link text-balance"
            href={withBase(localizePath(`/blog/${nextSlug}`, lang))}
          >
            {nextPostLabel}: {nextPost.data.title}{" "}
            <ArrowRight class="w-5 h-5 fill-current ml-4" />
          </Button>
        )
      }
    </div>
  </div>
</MainLayout>
