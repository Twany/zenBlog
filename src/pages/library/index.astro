---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpatialLibraryPage from '../../components/pages/SpatialLibraryPage.astro';
import { getBlogPosts } from '../../utils/blog';

const posts = await getBlogPosts('en');
---

<BaseLayout
  title="Spatial Library"
  description="Browse essays and notes as a spatial bookshelf archive."
  lang="en"
>
  <SpatialLibraryPage lang="en" posts={posts} />
</BaseLayout>
