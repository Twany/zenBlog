---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogPostPage from '../../../components/pages/BlogPostPage.astro';
import {
  getBlogPostImageUrl,
  getBlogPosts,
  getSlugFromEntry,
} from '../../../utils/blog';
import { SITE } from '../../../data/site';

export async function getStaticPaths() {
  const posts = await getBlogPosts('zh');
  return posts.map((entry) => ({
    params: { slug: getSlugFromEntry(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const posts = await getBlogPosts('zh');
const slug = getSlugFromEntry(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  type="article"
  lang="zh"
  image={getBlogPostImageUrl('zh', slug)}
  imageAlt={entry.data.title}
  article={{
    publishedTime: entry.data.pubDate.toISOString(),
    modifiedTime: entry.data.pubDate.toISOString(),
    author: SITE.author,
    tags: entry.data.tags ?? [],
  }}
>
  <BlogPostPage entry={entry} posts={posts} lang="zh" />
</BaseLayout>
