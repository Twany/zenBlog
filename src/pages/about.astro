---
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import getSiteConfig from "../site.config";
import coverImage from "../assets/images/1.png";
import { defaultLang, type Lang } from "../i18n/config";

const lang = (Astro.props?.lang as Lang) ?? defaultLang;
const siteConfig = getSiteConfig(lang);
const pageTitle = `${siteConfig.title} | ${siteConfig.about?.title ?? "About"}`;
---

<MainLayout activePage="about" pageTitle={pageTitle} lang={lang}>
  <div class="page-content">
    <h1 class="sigmar-ff text-balance">{siteConfig.about?.title}</h1>
    <Image
      width={1024}
      height={600}
      loading="eager"
      layout="constrained"
      class="rounded-4xl mb-8 mx-auto"
      src={coverImage}
      alt="An Astronaut walking on a terrain"
    />
    <p class="kanit-light text-left">
      {siteConfig.about?.text}
    </p>
  </div>
</MainLayout>
