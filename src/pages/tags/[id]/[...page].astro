---
import { getCollection, type CollectionEntry } from "astro:content";
import {
  getAllTags,
  getPostsByTag,
  sortItemsByDateDesc,
} from "../../../utils/helpers";
import type { GetStaticPathsOptions, Page } from "astro";
import getSiteConfig from "../../../site.config";
import MainLayout from "../../../layouts/MainLayout.astro";
import Pagination from "../../../components/Pagination.astro";
import PostListPreview from "../../../components/PostListPreview.astro";
import { defaultLang, type Lang } from "../../../i18n/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = (await getCollection("blogs"))
    .filter((post) => post.data.lang === defaultLang)
    .sort(sortItemsByDateDesc);
  const tags = getAllTags(posts);

  return tags.flatMap((tag) => {
    const filteredPosts = getPostsByTag(posts, tag.id);
    return paginate(filteredPosts, {
      params: { id: tag.id },
      pageSize: getSiteConfig(defaultLang).postsPerPage || 2,
    });
  });
}

type Props = { page: Page<CollectionEntry<"blogs">>; lang?: Lang };

const { page, lang = defaultLang } = Astro.props as Props;
const siteConfig = getSiteConfig(lang);
const blog = page.data;
const params = Astro.params;
const allPosts = await getCollection("blogs", (post) =>
  post.data.lang === lang && post.data.tags?.includes(params.id)
);
const allTags = getAllTags(allPosts);
const currentTag = allTags.find((tag) => tag.id === params.id);
const tagTitle = currentTag?.name
  ? `${currentTag.name} ${siteConfig.tags?.postsSuffix || "posts"}`
  : siteConfig.tags?.title || "Tags";
const pageTitle = `${siteConfig.title} | ${tagTitle}`;
---

<MainLayout activePage="tags" pageTitle={pageTitle} lang={lang}>
  <div class="page-content">
    <h2>
      {siteConfig.tags?.title || "Tags"}
      <span class="sigmar-ff"> · {currentTag?.name}</span>
    </h2>
    <div class="flex flex-col gap-8 max-w-full text-left mt-3">
      {blog.map((post) => <PostListPreview post={post} lang={lang} />)}
    </div>
    <Pagination page={page} class="mb-16 sm:mb-24" />
  </div>
</MainLayout>
