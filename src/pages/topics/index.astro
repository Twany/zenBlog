---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicsPage from '../../components/pages/TopicsPage.astro';
import { getBlogPosts } from '../../utils/blog';

const posts = await getBlogPosts('en');
---

<BaseLayout
  title="Topics"
  description="A topic map for AI workflows, design, code, publishing, and product thinking."
  lang="en"
>
  <TopicsPage lang="en" posts={posts} />
</BaseLayout>
