---
import SectionHeading from '../SectionHeading.astro';
import PostCard from '../PostCard.astro';
import { uiLabels } from '../../data/uiLabels';
import { formatDate } from '../../utils/date';
import {
  getBlogIndexUrl,
  getBlogPostImageUrl,
  getBlogPostUrl,
  getSlugFromEntry,
} from '../../utils/blog';
import type { BlogEntry } from '../../utils/blog';
import type { Locale } from '../../utils/i18n';
import Icon from '../Icon.astro';

interface Props {
  lang: Locale;
  posts: BlogEntry[];
}

const { lang, posts } = Astro.props as Props;
const heroPost = posts[0];
const latestPosts = posts.slice(0, 4);
const heroSlug = heroPost ? getSlugFromEntry(heroPost) : '';

const copy =
  lang === 'en'
    ? {
        eyebrow: 'Personal knowledge index',
        title:
          'A working archive for AI workflows, interface judgment, and slow product thinking.',
        intro:
          'Essays from real building sessions: what changed, why it changed, and what can be reused.',
        startHere: 'Start here',
        readNewest: 'Read newest',
        browseArchive: 'Browse archive',
        latest: 'Latest essays',
      }
    : {
        eyebrow: '个人知识入口',
        title:
          '一个持续工作的归档：AI 工作流、界面判断，以及慢一点的产品思考。',
        intro:
          '从真实构建过程里整理出的长文：改了什么、为什么改、哪些判断可以复用。',
        startHere: '从这里开始',
        readNewest: '阅读最新',
        browseArchive: '浏览归档',
        latest: '最新长文',
      };
---

<div class="animate-fade-in">
  <h1 class="sr-only">
    {lang === 'en' ? 'Twany Blog - Notes on Gradual Awakening' : '渐悟备忘录'}
  </h1>

  <section class="mx-auto mb-20 max-w-7xl px-6">
    <div
      class="grid grid-cols-1 gap-12 border-b border-slate-200 pb-16 lg:grid-cols-12 lg:gap-16"
    >
      <div class="lg:col-span-8">
        <p
          class="mb-5 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-brand-cyan"
        >
          {copy.eyebrow}
        </p>
        <h2
          class="max-w-5xl font-serif text-4xl font-normal leading-tight text-brand-dark text-balance md:text-6xl"
        >
          {copy.title}
        </h2>
        <p class="mt-7 max-w-3xl text-base leading-8 text-slate-600 md:text-lg">
          {copy.intro}
        </p>
      </div>

      <div class="lg:col-span-4">
        <div class="border-t border-slate-200 pt-5">
          <h2
            class="font-sans text-sm font-semibold uppercase tracking-widest text-brand-dark"
          >
            {copy.startHere}
          </h2>

          {
            heroPost ? (
              <a href={getBlogPostUrl(lang, heroSlug)} class="group mt-7 block">
                <div class="mb-5 aspect-[1200/630] overflow-hidden border border-slate-200 bg-slate-50">
                  <img
                    src={getBlogPostImageUrl(lang, heroSlug)}
                    alt={heroPost.data.title}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.015]"
                    loading="eager"
                    decoding="async"
                  />
                </div>
                <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-cyan">
                  {formatDate(heroPost.data.pubDate, lang)}
                </span>
                <h3 class="mt-3 font-serif text-2xl leading-tight text-brand-dark transition-colors group-hover:text-brand-cyan">
                  {heroPost.data.title}
                </h3>
              </a>
            ) : null
          }

          <div class="mt-8 flex flex-wrap gap-3">
            {
              heroPost ? (
                <a
                  href={getBlogPostUrl(lang, heroSlug)}
                  class="inline-flex min-h-11 items-center gap-2 border border-slate-200 px-3 text-xs font-semibold uppercase tracking-widest text-slate-600 transition-colors hover:border-brand-cyan hover:text-brand-cyan"
                >
                  {copy.readNewest}
                  <Icon name="arrow-right" size={14} />
                </a>
              ) : null
            }
            <a
              href={getBlogIndexUrl(lang)}
              class="inline-flex min-h-11 items-center gap-2 px-1 text-xs font-semibold uppercase tracking-widest text-brand-cyan transition-colors hover:text-brand-dark"
            >
              {copy.browseArchive}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    latestPosts.length ? (
      <section class="mx-auto mb-20 max-w-7xl px-6">
        <div class="border-t border-slate-200 pt-12">
          <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-baseline md:justify-between">
            <SectionHeading title={copy.latest} />
            <a
              href={getBlogIndexUrl(lang)}
              class="inline-flex min-h-11 items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-500 transition-colors hover:text-brand-cyan"
            >
              {uiLabels.common.viewArchive[lang]}
              <Icon name="arrow-right" size={14} />
            </a>
          </div>
          <div class="grid grid-cols-1 gap-x-10 gap-y-12 md:grid-cols-2">
            {latestPosts.map((post, index) => {
              const slug = getSlugFromEntry(post);
              return (
                <PostCard
                  lang={lang}
                  href={getBlogPostUrl(lang, slug)}
                  title={post.data.title}
                  excerpt={post.data.description}
                  date={formatDate(post.data.pubDate, lang)}
                  image={getBlogPostImageUrl(lang, slug)}
                  imageAlt={post.data.title}
                  showCategory={false}
                  showReadTime={false}
                  showTags={false}
                  showExcerpt={false}
                  featured={index === 0}
                />
              );
            })}
          </div>
        </div>
      </section>
    ) : null
  }
</div>
