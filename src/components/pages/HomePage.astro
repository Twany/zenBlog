---
import SectionHeading from '../SectionHeading.astro';
import PostCard from '../PostCard.astro';
import ExperimentCard from '../ExperimentCard.astro';
import { uiLabels } from '../../data/uiLabels';
import { notes } from '../../data/notes';
import { experiments } from '../../data/experiments';
import { formatDate } from '../../utils/date';
import {
  getBlogIndexUrl,
  getBlogPostUrl,
  getSlugFromEntry,
} from '../../utils/blog';
import { getLocalizedPath } from '../../utils/i18n';
import { getTopicSummaries } from '../../utils/topics';
import type { BlogEntry } from '../../utils/blog';
import type { Locale } from '../../utils/i18n';
import Icon from '../Icon.astro';

interface Props {
  lang: Locale;
  posts: BlogEntry[];
}

const { lang, posts } = Astro.props as Props;
const heroPost = posts[0];
const latestPosts = posts.slice(0, 4);
const featuredExperiments = experiments.slice(0, 4);
const recentNotes = notes.slice(0, 4);
const featuredTopics = getTopicSummaries(posts, lang).slice(0, 5);
const codexPost = posts.find(
  (post) => getSlugFromEntry(post) === 'codex-blog-publishing-system'
);

const copy =
  lang === 'en'
    ? {
        eyebrow: 'Personal knowledge index',
        title:
          'A working archive for AI workflows, interface judgment, and slow product thinking.',
        intro:
          'I use this site to turn real building sessions into durable notes: what changed, why it changed, what survived verification, and what can be reused next time.',
        startHere: 'Start here',
        startDescription:
          'Begin with the newest long-form piece, then move through topics instead of scrolling a raw archive.',
        readNewest: 'Read newest',
        browseArchive: 'Browse archive',
        topicMap: 'Topic map',
        tracks: 'Reading tracks',
        tracksIntro:
          'The archive is organized around recurring problems rather than content formats.',
        latest: 'Latest essays',
        signals: 'Current signals',
        signalsIntro:
          'Short notes and build artifacts that show what is becoming article material.',
        building: 'Now building',
        builtSystem: 'Codex-to-blog publishing system',
        builtSystemText:
          'A direct-publish workflow with bilingual posts, templates, OG images, validation, Cloudflare deploy, and live checks.',
        posts: 'essays',
        topics: 'topics',
        notes: 'notes',
      }
    : {
        eyebrow: '个人知识入口',
        title:
          '一个持续工作的归档：AI 工作流、界面判断，以及慢一点的产品思考。',
        intro:
          '我把真实构建过程沉淀到这里：改了什么、为什么改、如何验证、哪些判断可以在下一次复用。',
        startHere: '从这里开始',
        startDescription:
          '先读最新长文，再按主题进入归档，而不是在时间线里盲翻。',
        readNewest: '阅读最新',
        browseArchive: '浏览归档',
        topicMap: '专题地图',
        tracks: '阅读轨道',
        tracksIntro: '这个归档按反复出现的问题组织，而不只是按内容形式分类。',
        latest: '最新长文',
        signals: '当前信号',
        signalsIntro: '短笔记和构建产物，记录哪些东西正在变成文章素材。',
        building: '正在构建',
        builtSystem: 'Codex 到博客的发布系统',
        builtSystemText:
          '一条直发工作流：中英双语长文、模板、OG 图、内容校验、Cloudflare 部署和线上检查。',
        posts: '篇长文',
        topics: '个专题',
        notes: '条笔记',
      };

const stats = [
  { value: posts.length, label: copy.posts },
  { value: featuredTopics.length, label: copy.topics },
  { value: notes.length, label: copy.notes },
];
---

<div class="animate-fade-in">
  <h1 class="sr-only">
    {lang === 'en' ? 'Twany Blog - Notes on Gradual Awakening' : '渐悟备忘录'}
  </h1>

  <section class="mx-auto mb-20 max-w-7xl px-6">
    <div
      class="grid grid-cols-1 gap-12 border-b border-slate-200 pb-16 lg:grid-cols-12 lg:gap-16"
    >
      <div class="lg:col-span-8">
        <p
          class="mb-5 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-brand-cyan"
        >
          {copy.eyebrow}
        </p>
        <h2
          class="max-w-5xl font-serif text-4xl font-normal leading-tight text-brand-dark text-balance md:text-6xl"
        >
          {copy.title}
        </h2>
        <p class="mt-7 max-w-3xl text-base leading-8 text-slate-600 md:text-lg">
          {copy.intro}
        </p>

        <div
          class="mt-10 grid grid-cols-3 gap-4 border-y border-slate-200 py-5"
        >
          {
            stats.map((stat) => (
              <div>
                <div class="font-serif text-3xl text-brand-dark">
                  {stat.value}
                </div>
                <div class="mt-1 text-xs font-semibold uppercase tracking-widest text-slate-500">
                  {stat.label}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-4">
        <div class="border-t border-slate-200 pt-5">
          <h2
            class="font-sans text-sm font-semibold uppercase tracking-widest text-brand-dark"
          >
            {copy.startHere}
          </h2>
          <p class="mt-4 text-sm leading-7 text-slate-600">
            {copy.startDescription}
          </p>

          {
            heroPost ? (
              <a
                href={getBlogPostUrl(lang, getSlugFromEntry(heroPost))}
                class="group mt-8 block border-t border-slate-200 pt-5"
              >
                <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-cyan">
                  {formatDate(heroPost.data.pubDate, lang)}
                </span>
                <h3 class="mt-3 font-serif text-2xl leading-tight text-brand-dark transition-colors group-hover:text-brand-cyan">
                  {heroPost.data.title}
                </h3>
                <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600">
                  {heroPost.data.description}
                </p>
              </a>
            ) : null
          }

          <div class="mt-8 flex flex-wrap gap-3">
            {
              heroPost ? (
                <a
                  href={getBlogPostUrl(lang, getSlugFromEntry(heroPost))}
                  class="inline-flex min-h-11 items-center gap-2 border border-slate-200 px-3 text-xs font-semibold uppercase tracking-widest text-slate-600 transition-colors hover:border-brand-cyan hover:text-brand-cyan"
                >
                  {copy.readNewest}
                  <Icon name="arrow-right" size={14} />
                </a>
              ) : null
            }
            <a
              href={getBlogIndexUrl(lang)}
              class="inline-flex min-h-11 items-center gap-2 px-1 text-xs font-semibold uppercase tracking-widest text-brand-cyan transition-colors hover:text-brand-dark"
            >
              {copy.browseArchive}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    featuredTopics.length ? (
      <section class="mx-auto mb-20 max-w-7xl px-6">
        <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div>
            <h2 class="font-serif text-4xl font-normal text-brand-dark md:text-5xl">
              {copy.tracks}
            </h2>
            <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600">
              {copy.tracksIntro}
            </p>
          </div>
          <a
            href={getLocalizedPath('/topics/', lang)}
            class="inline-flex min-h-11 items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-500 transition-colors hover:text-brand-cyan"
          >
            {copy.topicMap}
            <Icon name="arrow-right" size={14} />
          </a>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-5">
          {featuredTopics.map((topic, index) => (
            <a
              href={topic.href}
              class={`group border-t border-slate-200 pt-5 ${
                index === 0 ? 'md:col-span-2' : ''
              }`}
            >
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-cyan">
                {topic.kind} / {topic.count}
              </span>
              <h3 class="mt-3 font-serif text-2xl leading-tight text-brand-dark transition-colors group-hover:text-brand-cyan">
                {topic.name}
              </h3>
              <p class="mt-4 line-clamp-4 text-sm leading-6 text-slate-600">
                {topic.description}
              </p>
            </a>
          ))}
        </div>
      </section>
    ) : null
  }

  {
    latestPosts.length ? (
      <section class="mx-auto mb-20 max-w-7xl px-6">
        <div class="border-t border-slate-200 pt-12">
          <div class="mb-10 flex flex-col gap-5 md:flex-row md:items-baseline md:justify-between">
            <SectionHeading title={copy.latest} />
            <a
              href={getBlogIndexUrl(lang)}
              class="inline-flex min-h-11 items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-500 transition-colors hover:text-brand-cyan"
            >
              {uiLabels.common.viewArchive[lang]}
              <Icon name="arrow-right" size={14} />
            </a>
          </div>
          <div class="grid grid-cols-1 gap-x-10 gap-y-12 md:grid-cols-2">
            {latestPosts.map((post, index) => (
              <PostCard
                lang={lang}
                href={getBlogPostUrl(lang, getSlugFromEntry(post))}
                title={post.data.title}
                excerpt={post.data.description}
                category={post.data.category}
                date={formatDate(post.data.pubDate, lang)}
                readTime={post.data.readTime}
                tags={post.data.tags ?? []}
                featured={index === 0}
              />
            ))}
          </div>
        </div>
      </section>
    ) : null
  }

  <section class="mx-auto mb-20 max-w-7xl px-6">
    <div
      class="grid grid-cols-1 gap-12 border-t border-slate-200 pt-12 lg:grid-cols-12"
    >
      <div class="lg:col-span-4">
        <h2 class="font-serif text-4xl font-normal text-brand-dark md:text-5xl">
          {copy.signals}
        </h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          {copy.signalsIntro}
        </p>
      </div>

      <div class="lg:col-span-4">
        <h3
          class="mb-6 font-sans text-sm font-semibold uppercase tracking-widest text-brand-dark"
        >
          {uiLabels.common.latestNotes[lang]}
        </h3>
        <div class="space-y-6">
          {
            recentNotes.map((note) => (
              <div class="border-t border-slate-200 pt-4">
                <span class="font-mono text-[11px] uppercase tracking-wider text-slate-500">
                  {note.date}
                </span>
                <p class="mt-2 font-serif text-sm leading-relaxed text-slate-700 line-clamp-3">
                  {note.content[lang]}
                </p>
              </div>
            ))
          }
        </div>
        <a
          href={getLocalizedPath('/notes/', lang)}
          class="mt-7 inline-flex min-h-11 items-center gap-2 text-xs font-semibold uppercase tracking-widest text-brand-cyan transition-colors hover:text-brand-dark"
        >
          {uiLabels.common.viewAllNotes[lang]}
          <Icon name="arrow-right" size={12} />
        </a>
      </div>

      <div class="lg:col-span-4">
        <h3
          class="mb-6 font-sans text-sm font-semibold uppercase tracking-widest text-brand-dark"
        >
          {copy.building}
        </h3>
        <a
          href={codexPost
            ? getBlogPostUrl(lang, getSlugFromEntry(codexPost))
            : getBlogIndexUrl(lang)}
          class="group block border-t border-slate-200 pt-4"
        >
          <span
            class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-cyan"
          >
            AI Workflow
          </span>
          <h4
            class="mt-3 font-serif text-2xl leading-tight text-brand-dark transition-colors group-hover:text-brand-cyan"
          >
            {copy.builtSystem}
          </h4>
          <p class="mt-4 text-sm leading-7 text-slate-600">
            {copy.builtSystemText}
          </p>
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto mb-20 max-w-7xl px-6">
    <div class="border-t border-slate-200 pt-12">
      <div
        class="mb-12 flex flex-col gap-6 md:flex-row md:items-baseline md:justify-between"
      >
        <h2 class="font-serif text-4xl font-normal text-brand-dark lg:text-5xl">
          {uiLabels.common.lab[lang]}
        </h2>
        <a
          href={getLocalizedPath('/experiments/', lang)}
          class="inline-flex min-h-11 items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-500 transition-colors hover:text-brand-cyan"
        >
          {uiLabels.common.viewArchive[lang]}
          <Icon name="arrow-right" size={14} />
        </a>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        {
          featuredExperiments.map((exp) => (
            <ExperimentCard experiment={exp} lang={lang} />
          ))
        }
      </div>
    </div>
  </section>
</div>
