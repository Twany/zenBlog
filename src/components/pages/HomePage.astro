---
import SectionHeading from '../SectionHeading.astro';
import PostCard from '../PostCard.astro';
import { uiLabels } from '../../data/uiLabels';
import { formatDate } from '../../utils/date';
import {
  getBlogIndexUrl,
  getBlogPostFeatureImageUrl,
  getBlogPostUrl,
  getSlugFromEntry,
} from '../../utils/blog';
import type { BlogEntry } from '../../utils/blog';
import type { Locale } from '../../utils/i18n';
import Icon from '../Icon.astro';

interface Props {
  lang: Locale;
  posts: BlogEntry[];
}

const { lang, posts } = Astro.props as Props;
const popularPosts = posts.slice(0, 3);
const startPosts = posts.slice(0, 4);

const copy =
  lang === 'en'
    ? {
        eyebrow: 'Personal knowledge index',
        title:
          'A working archive for AI workflows, interface judgment, and slow product thinking.',
        intro:
          'Essays from real building sessions: what changed, why it changed, and what can be reused.',
        browseArchive: 'View all new',
        popular: 'Popular essays',
      }
    : {
        eyebrow: '个人知识入口',
        title:
          '一个持续工作的归档：AI 工作流、界面判断，以及慢一点的产品思考。',
        intro:
          '从真实构建过程里整理出的长文：改了什么、为什么改、哪些判断可以复用。',
        browseArchive: '查看全部',
        popular: '热门长文',
      };
---

<div class="animate-fade-in">
  <h1 class="sr-only">
    {lang === 'en' ? 'Twany Blog - Notes on Gradual Awakening' : '渐悟备忘录'}
  </h1>

  <section class="mx-auto mb-14 max-w-7xl px-6 md:mb-16">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="max-w-3xl lg:col-span-7">
        <p class="mb-5 font-serif text-base italic text-brand-cyan">
          {copy.eyebrow}
        </p>
        <h2
          class="font-serif text-4xl font-normal leading-tight text-brand-dark text-balance md:text-5xl lg:text-6xl"
        >
          {copy.title}
        </h2>
        <p class="mt-7 max-w-2xl text-base leading-8 text-slate-600 md:text-lg">
          {copy.intro}
        </p>
      </div>

      <div class="lg:col-span-5">
        <div class="border-t border-slate-200 pt-5">
          <div class="space-y-6">
            {
              startPosts.map((post) => {
                const slug = getSlugFromEntry(post);
                return (
                  <a
                    href={getBlogPostUrl(lang, slug)}
                    class="group block border-t border-slate-200 pt-5 first:border-t-0 first:pt-0"
                  >
                    <span class="font-serif text-xl text-slate-500">
                      {formatDate(post.data.pubDate, lang)}
                    </span>
                    <h3 class="mt-3 font-sans text-2xl font-semibold leading-tight text-brand-dark transition-colors group-hover:text-brand-cyan">
                      {post.data.title}
                    </h3>
                  </a>
                );
              })
            }
          </div>

          <div class="mt-8">
            <a
              href={getBlogIndexUrl(lang)}
              class="inline-flex min-h-11 items-center gap-2 border-b border-slate-200 text-sm font-medium text-slate-600 transition-colors hover:border-brand-cyan hover:text-brand-cyan"
            >
              {copy.browseArchive}
              <Icon name="arrow-right" size={14} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    popularPosts.length ? (
      <section class="mx-auto mb-20 max-w-7xl px-6">
        <div>
          <div class="mb-6 flex flex-col gap-3 md:flex-row md:items-baseline md:justify-between">
            <SectionHeading title={copy.popular} />
            <a
              href={getBlogIndexUrl(lang)}
              class="inline-flex min-h-11 items-center gap-2 text-sm font-medium text-slate-500 transition-colors hover:text-brand-cyan"
            >
              {uiLabels.common.viewArchive[lang]}
              <Icon name="arrow-right" size={14} />
            </a>
          </div>
          <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 lg:grid-cols-3">
            {popularPosts.map((post) => {
              const slug = getSlugFromEntry(post);
              return (
                <PostCard
                  lang={lang}
                  href={getBlogPostUrl(lang, slug)}
                  title={post.data.title}
                  excerpt={post.data.description}
                  date={formatDate(post.data.pubDate, lang)}
                  image={getBlogPostFeatureImageUrl(slug)}
                  imageAlt={post.data.title}
                  showCategory={false}
                  showReadTime={false}
                  showTags={false}
                  showExcerpt={false}
                />
              );
            })}
          </div>
        </div>
      </section>
    ) : null
  }
</div>
