---
import SectionHeading from '../SectionHeading.astro';
import PostCard from '../PostCard.astro';
import ExperimentCard from '../ExperimentCard.astro';
import { uiLabels } from '../../data/uiLabels';
import { notes } from '../../data/notes';
import { experiments } from '../../data/experiments';
import { formatDate } from '../../utils/date';
import {
  getBlogIndexUrl,
  getBlogPostUrl,
  getSlugFromEntry,
} from '../../utils/blog';
import { getLocalizedPath } from '../../utils/i18n';
import { getTopicSummaries } from '../../utils/topics';
import type { BlogEntry } from '../../utils/blog';
import type { Locale } from '../../utils/i18n';
import Icon from '../Icon.astro';

interface Props {
  lang: Locale;
  posts: BlogEntry[];
}

const { lang, posts } = Astro.props as Props;
const heroPost = posts[0];
const subPosts = posts.slice(1, 3);
const popularPosts = posts.slice(3, 6);
const featuredExperiments = experiments.slice(0, 4);
const recentNotes = notes.slice(0, 4);
const featuredTopics = getTopicSummaries(posts, lang).slice(0, 4);
const positioning =
  lang === 'en'
    ? 'Notes on AI workflows, interface craft, code, and slow product thinking.'
    : '记录 AI 工作流、界面手感、代码，以及慢一点的产品思考。';
const topicsCopy =
  lang === 'en'
    ? {
        title: 'Topic Map',
        viewAll: 'View topics',
        articles: 'articles',
        article: 'article',
      }
    : {
        title: '专题地图',
        viewAll: '查看专题',
        articles: '篇文章',
        article: '篇文章',
      };
---

<div class="animate-fade-in">
  <h1 class="sr-only">
    {lang === 'en' ? 'Twany Blog - Notes on Gradual Awakening' : '渐悟备忘录'}
  </h1>

  <section class="max-w-7xl mx-auto px-6 mb-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-8 flex flex-col gap-12">
        <div class="flex items-start justify-between mb-2 gap-8">
          <div>
            <h2
              class="font-serif text-4xl lg:text-5xl text-brand-dark font-normal text-balance"
            >
              {uiLabels.common.recently[lang]}
            </h2>
            <p
              class="mt-4 max-w-2xl text-sm md:text-base leading-7 text-slate-600"
            >
              {positioning}
            </p>
          </div>
          <a
            href={getBlogIndexUrl(lang)}
            class="hidden md:flex min-h-11 items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-500 hover:text-brand-cyan transition-colors focus-visible:outline-none"
          >
            {uiLabels.common.viewArchive[lang]}
            <Icon name="arrow-right" size={14} />
          </a>
        </div>

        {
          heroPost ? (
            <div class="mb-4">
              <PostCard
                lang={lang}
                href={getBlogPostUrl(lang, getSlugFromEntry(heroPost))}
                title={heroPost.data.title}
                excerpt={heroPost.data.description}
                category={heroPost.data.category}
                date={formatDate(heroPost.data.pubDate, lang)}
                readTime={heroPost.data.readTime}
                tags={heroPost.data.tags ?? []}
                featured
              />
            </div>
          ) : null
        }

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-12">
          {
            subPosts.map((post) => (
              <PostCard
                lang={lang}
                href={getBlogPostUrl(lang, getSlugFromEntry(post))}
                title={post.data.title}
                excerpt={post.data.description}
                category={post.data.category}
                date={formatDate(post.data.pubDate, lang)}
                readTime={post.data.readTime}
                tags={post.data.tags ?? []}
              />
            ))
          }
        </div>

        <a
          href={getBlogIndexUrl(lang)}
          class="md:hidden w-full py-4 border border-gray-200 text-xs font-semibold uppercase tracking-widest text-gray-500 hover:border-brand-cyan hover:text-brand-cyan transition-colors text-center"
        >
          {uiLabels.common.viewArchive[lang]}
        </a>
      </div>

      <div class="lg:col-span-4">
        <div class="sticky top-32 border-t border-slate-200 pt-5">
          <div class="flex items-center justify-between mb-8">
            <h2
              class="font-sans font-semibold text-sm uppercase tracking-widest text-brand-dark"
            >
              {uiLabels.common.latestNotes[lang]}
            </h2>
          </div>

          <div class="space-y-7">
            {
              recentNotes.map((note) => (
                <div class="group">
                  <div class="flex flex-col gap-2">
                    <span class="font-mono text-[11px] text-slate-500 uppercase tracking-wider">
                      {note.date}
                    </span>
                    <p class="font-serif text-gray-700 text-sm leading-relaxed line-clamp-3">
                      {note.content[lang]}
                    </p>
                    {note.tags ? (
                      <div class="flex flex-wrap gap-1 mt-1">
                        {note.tags.slice(0, 2).map((tag) => (
                          <span class="text-[10px] uppercase font-semibold text-slate-500">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    ) : null}
                  </div>
                </div>
              ))
            }
          </div>

          <div class="mt-8 pt-5 border-t border-gray-200">
            <a
              href={getLocalizedPath('/notes/', lang)}
              class="min-h-11 text-xs font-semibold uppercase tracking-widest text-brand-cyan hover:text-brand-dark transition-colors flex items-center gap-2"
            >
              {uiLabels.common.viewAllNotes[lang]}
              <Icon name="arrow-right" size={12} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {
    featuredTopics.length ? (
      <section class="max-w-7xl mx-auto px-6 mb-20">
        <div class="border-t border-slate-200 pt-12">
          <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-10 gap-6">
            <h2 class="font-serif text-4xl lg:text-5xl text-brand-dark font-normal text-balance">
              {topicsCopy.title}
            </h2>
            <a
              href={getLocalizedPath('/topics/', lang)}
              class="inline-flex min-h-11 items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-500 hover:text-brand-cyan transition-colors"
            >
              {topicsCopy.viewAll}
              <Icon name="arrow-right" size={14} />
            </a>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {featuredTopics.map((topic) => (
              <a
                href={topic.href}
                class="group border-t border-slate-200 pt-5 min-h-48 flex flex-col"
              >
                <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-cyan">
                  {topic.kind}
                </span>
                <h3 class="mt-3 font-serif text-2xl text-brand-dark group-hover:text-brand-cyan transition-colors">
                  {topic.name}
                </h3>
                <p class="mt-4 text-sm leading-6 text-slate-600 line-clamp-3">
                  {topic.description}
                </p>
                <span class="mt-auto pt-5 text-xs font-semibold uppercase tracking-widest text-slate-500">
                  {topic.count}{' '}
                  {topic.count === 1 ? topicsCopy.article : topicsCopy.articles}
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    ) : null
  }

  {
    popularPosts.length ? (
      <section class="max-w-7xl mx-auto px-6 mb-20">
        <SectionHeading title={uiLabels.common.popular[lang]} />
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
          {popularPosts.map((post) => (
            <PostCard
              lang={lang}
              href={getBlogPostUrl(lang, getSlugFromEntry(post))}
              title={post.data.title}
              excerpt={post.data.description}
              category={post.data.category}
              date={formatDate(post.data.pubDate, lang)}
              readTime={post.data.readTime}
              tags={post.data.tags ?? []}
            />
          ))}
        </div>
      </section>
    ) : null
  }

  <section class="max-w-7xl mx-auto px-6 mb-20">
    <div class="border-t border-slate-200 pt-12">
      <div
        class="flex flex-col md:flex-row md:items-baseline justify-between mb-12 gap-6"
      >
        <div>
          <h2
            class="font-serif text-4xl lg:text-5xl text-brand-dark font-normal text-balance"
          >
            {uiLabels.common.lab[lang]}
          </h2>
        </div>
        <a
          href={getLocalizedPath('/experiments/', lang)}
          class="inline-flex min-h-11 items-center text-xs font-semibold uppercase tracking-widest text-slate-500 hover:text-brand-cyan transition-colors"
        >
          {uiLabels.common.viewArchive[lang]}
          <span class="ml-2">→</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          featuredExperiments.map((exp) => (
            <ExperimentCard experiment={exp} lang={lang} />
          ))
        }
      </div>
    </div>
  </section>
</div>
