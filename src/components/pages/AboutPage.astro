---
import SectionHeading from '../SectionHeading.astro';
import { uiLabels } from '../../data/uiLabels';
import aboutData from '../../data/about.json';
import type { Locale } from '../../utils/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const intro = aboutData.intro[lang];
const toolkit = aboutData.toolkit;
const quote = aboutData.quote;
---
<div class="max-w-7xl mx-auto px-6">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
    <div>
      <SectionHeading title={uiLabels.common.whoIs[lang]} as="h1" />

      <div class="font-serif text-gray-700 leading-relaxed space-y-6 text-lg">
        {intro.map((paragraph) => (
          <p>
            {paragraph.label && (
              <strong class="font-sans uppercase text-brand-cyan tracking-widest text-sm block mb-1">
                {paragraph.label}
              </strong>
            )}
            {paragraph.content}
          </p>
        ))}

        <div class="pt-8">
          <h3 class="font-sans font-semibold text-sm uppercase tracking-widest text-brand-dark mb-6">Toolkit</h3>
          <div class="grid grid-cols-2 gap-4 font-sans text-sm font-semibold uppercase tracking-wide">
            <div class="space-y-2">
              {toolkit.slice(0, Math.ceil(toolkit.length / 2)).map((item) => (
                  <div class="flex items-center gap-2 text-slate-600">
                  <span class="w-2 h-px bg-brand-cyan"></span>
                  {item}
                </div>
              ))}
            </div>
            <div class="space-y-2">
              {toolkit.slice(Math.ceil(toolkit.length / 2)).map((item) => (
                  <div class="flex items-center gap-2 text-slate-600">
                  <span class="w-2 h-px bg-brand-cyan"></span>
                  {item}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="border-l border-brand-cyan pl-8 lg:mt-28">
      <p class="text-brand-dark font-serif italic text-2xl leading-relaxed">"{quote.text}"</p>
      <p class="text-brand-cyan mt-4 font-sans uppercase font-semibold text-sm tracking-widest">— {quote.author}</p>
    </div>
  </div>
</div>
