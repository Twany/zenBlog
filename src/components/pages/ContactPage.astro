---
import Icon from '../Icon.astro';
import { uiLabels } from '../../data/uiLabels';
import type { Locale } from '../../utils/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const contactEmail = 'hello@twany.me';
---

<div class="max-w-7xl mx-auto px-6">
  <div
    class="grid grid-cols-1 gap-12 border-t border-slate-200 pt-10 lg:grid-cols-12"
  >
    <div class="lg:col-span-4">
      <h1
        class="font-serif text-5xl font-normal mb-8 text-brand-dark text-balance"
      >
        {uiLabels.common.getInTouch[lang]}
      </h1>
      <p class="font-serif mb-12 text-slate-600 leading-relaxed">
        {
          lang === 'en'
            ? 'Whether you have a question about code, a project proposal, or just want to say hello, my inbox is always open.'
            : '无论您是有关于代码的问题，项目建议，还是只是想打个招呼，我的收件箱随时为您敞开。'
        }
      </p>

      <div class="space-y-6">
        <a
          href={`mailto:${contactEmail}`}
          class="flex items-center gap-4 transition-colors hover:text-brand-cyan"
        >
          <Icon name="mail" class="w-5 h-5 text-brand-cyan" />
          <span class="font-sans font-semibold text-brand-dark"
            >{contactEmail}</span
          >
        </a>
        <div class="flex items-center gap-4">
          <Icon name="map-pin" class="w-5 h-5 text-brand-cyan" />
          <span class="font-sans font-semibold text-brand-dark"
            >Sydney, Australia</span
          >
        </div>
      </div>
    </div>

    <div class="lg:col-span-8">
      <div class="max-w-lg border border-slate-200 p-6 md:p-8">
        <h2 class="font-sans text-sm font-semibold text-brand-dark">
          {lang === 'en' ? 'Best way to reach me' : '最直接的联系渠道'}
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-600">
          {
            lang === 'en'
              ? 'Send a short email with context, links, and what kind of response would be useful. I read mail directly, so there is no hidden contact form behind this page.'
              : '直接发一封带上下文、链接和期望回复方式的邮件即可。这里不再放一个看起来能站内提交、实际依赖邮件客户端的表单。'
          }
        </p>
        <a
          href={`mailto:${contactEmail}`}
          class="mt-6 inline-flex min-h-12 items-center gap-2 border border-brand-dark bg-brand-dark px-6 py-3 font-sans text-sm font-semibold text-white transition-colors hover:border-brand-cyan hover:bg-brand-cyan"
        >
          <Icon name="mail" size={16} />
          {contactEmail}
        </a>
      </div>
    </div>
  </div>
</div>
