---
import Icon from '../Icon.astro';
import { formatDate } from '../../utils/date';
import {
  getBlogPostUrl,
  getSlugFromEntry,
  type BlogEntry,
} from '../../utils/blog';
import type { Locale } from '../../utils/i18n';

interface Props {
  lang: Locale;
  posts: BlogEntry[];
}

type Shelf = {
  id: string;
  category: string;
  posts: BlogEntry[];
  accent: string;
  tone: string;
};

const { lang, posts } = Astro.props as Props;

const copy = {
  en: {
    pageTitle: 'Spatial Library',
    deck: 'All writing as shelves',
    intro:
      'Browse the archive as a room of shelves. Each book is a real article; focus or hover to pull it out and preview the contents.',
    allShelves: 'All shelves',
    articleLabel: posts.length === 1 ? 'article' : 'articles',
    themes: 'Themes',
    open: 'Open article',
    classic: 'Classic archive',
    shelf: 'Shelf',
    longform: 'Longform',
    essay: 'Essay',
    brief: 'Brief',
    empty: 'Room reserved for future notes.',
    readingPath: 'Reading path',
    startHere: 'Start here',
    latestPath: 'Latest',
    longformPath: 'Longform',
    preview: 'Preview',
  },
  zh: {
    pageTitle: '空间图书馆',
    deck: '把所有写作变成书架',
    intro:
      '用一面有空间感的书柜浏览归档。每一本书都来自真实文章；悬停或聚焦时会抽出并显示预览。',
    allShelves: '全部书架',
    articleLabel: '篇文章',
    themes: '主题',
    open: '打开文章',
    classic: '传统归档',
    shelf: '书架',
    longform: '长文',
    essay: '文章',
    brief: '短篇',
    empty: '这里留给未来的笔记。',
    readingPath: '阅读路径',
    startHere: '从这里开始',
    latestPath: '最新',
    longformPath: '长文',
    preview: '预览',
  },
}[lang];

const palette = [
  { accent: '#56c7c9', tone: '#234f54' },
  { accent: '#d99b66', tone: '#5a3528' },
  { accent: '#8cad73', tone: '#394936' },
  { accent: '#8ca7c8', tone: '#263c55' },
  { accent: '#c98484', tone: '#563033' },
];

const bookTones = [
  '#243f44',
  '#4f352b',
  '#354936',
  '#263c55',
  '#51333d',
  '#6d5a43',
];

const shelfMap = posts.reduce((map, post) => {
  const key = post.data.category;
  const current = map.get(key) ?? [];
  current.push(post);
  map.set(key, current);
  return map;
}, new Map<string, BlogEntry[]>());

const shelves: Shelf[] = Array.from(shelfMap.entries()).map(
  ([category, shelfPosts], index) => ({
    id: `shelf-${index}`,
    category,
    posts: shelfPosts,
    accent: palette[index % palette.length].accent,
    tone: palette[index % palette.length].tone,
  })
);

const latestPost = posts[0];
const archiveHref = lang === 'en' ? '/blog/' : '/zh/blog/';

const getReadMinutes = (readTime: string) => {
  const match = readTime.match(/\d+/);
  return match ? Number(match[0]) : 0;
};

const getFormatLabel = (readTime: string) => {
  const minutes = getReadMinutes(readTime);
  if (minutes >= 15) return copy.longform;
  if (minutes >= 8) return copy.essay;
  return copy.brief;
};

const trimTitle = (title: string, limit = lang === 'zh' ? 18 : 24) => {
  if (title.length <= limit) return title;
  return `${title.slice(0, limit - 1)}...`;
};

const englishSpineStopWords = new Set([
  'a',
  'an',
  'and',
  'as',
  'for',
  'from',
  'how',
  'in',
  'inside',
  'into',
  'of',
  'on',
  'that',
  'the',
  'to',
  'with',
]);

const getSpineTitle = (post: BlogEntry) => {
  if (lang === 'zh') return trimTitle(post.data.title, 14);

  const titleLead = post.data.title
    .split(/[:：—–-]/)[0]
    .replace(/[“”"']/g, '')
    .trim();
  const meaningfulWords = titleLead
    .split(/\s+/)
    .map((word) => word.replace(/[’']s$/i, '').replace(/[^A-Za-z0-9]/g, ''))
    .filter((word) => word && !englishSpineStopWords.has(word.toLowerCase()));

  const shortLabel =
    meaningfulWords.length > 0
      ? meaningfulWords.slice(0, 3).join(' ')
      : titleLead.split(/\s+/).slice(0, 3).join(' ');

  return trimTitle(shortLabel, 22);
};

const getSpineTitleParts = (post: BlogEntry) =>
  getSpineTitle(post).split(/\s+/).filter(Boolean);

const getBookTone = (shelfIndex: number, postIndex: number) =>
  bookTones[(shelfIndex + postIndex) % bookTones.length];

const longformPost =
  posts.find((post) => getReadMinutes(post.data.readTime) >= 15) ?? null;

const readingPaths: {
  label: string;
  title: string;
  href: string;
  icon: 'book-open' | 'clock' | 'list';
}[] = [];
const usedPathHrefs = new Set<string>();

const addReadingPath = (
  path: (typeof readingPaths)[number] | null | undefined
) => {
  if (!path || usedPathHrefs.has(path.href)) return;
  usedPathHrefs.add(path.href);
  readingPaths.push(path);
};

addReadingPath(
  latestPost
    ? {
        label: `${copy.startHere} · ${copy.latestPath}`,
        title: latestPost.data.title,
        href: getBlogPostUrl(lang, getSlugFromEntry(latestPost)),
        icon: 'book-open',
      }
    : null
);
addReadingPath(
  longformPost
    ? {
        label: copy.longformPath,
        title: longformPost.data.title,
        href: getBlogPostUrl(lang, getSlugFromEntry(longformPost)),
        icon: 'book-open',
      }
    : null
);
addReadingPath({
  label: copy.classic,
  title: copy.allShelves,
  href: archiveHref,
  icon: 'list',
});
---

<div class="spatial-library" data-lang={lang}>
  <aside class="library-sidebar" aria-label={copy.themes}>
    <div class="sidebar-mark">
      <span class="mark-glyph"><Icon name="book-open" size={24} /></span>
      <span>{copy.pageTitle}</span>
    </div>

    <div class="sidebar-title">
      <p>{copy.deck}</p>
      <strong>{posts.length}</strong>
      <span>{copy.articleLabel}</span>
    </div>

    <nav class="shelf-nav" aria-label={copy.allShelves}>
      <a
        href="#library-wall"
        class="shelf-nav-link is-active"
        data-shelf-link="library-wall"
        aria-current="location"
      >
        <Icon name="library" size={18} />
        <span>{copy.allShelves}</span>
        <em>{posts.length}</em>
      </a>
      {
        shelves.map((shelf) => (
          <a
            href={`#${shelf.id}`}
            class="shelf-nav-link"
            data-shelf-link={shelf.id}
          >
            <Icon name="book-open" size={18} />
            <span>{shelf.category}</span>
            <em>{shelf.posts.length}</em>
          </a>
        ))
      }
    </nav>
  </aside>

  <section
    class="library-stage"
    id="library-wall"
    aria-labelledby="library-title"
  >
    <div class="library-toolbar">
      <div>
        <h1 id="library-title">{copy.pageTitle}</h1>
        <p>{copy.intro}</p>
      </div>
    </div>

    {
      readingPaths.length > 0 ? (
        <nav class="reading-paths" aria-label={copy.readingPath}>
          <span>{copy.readingPath}</span>
          {readingPaths.map((path) => (
            <a href={path.href} class="reading-path-link">
              <Icon name={path.icon} size={15} />
              <em>{path.label}</em>
              <strong>{trimTitle(path.title, lang === 'zh' ? 14 : 22)}</strong>
            </a>
          ))}
        </nav>
      ) : null
    }

    {
      shelves.length > 0 ? (
        <div class="shelf-wall" aria-label={copy.themes}>
          {shelves.map((shelf, shelfIndex) => (
            <section
              class="shelf-bay"
              id={shelf.id}
              data-shelf-section={shelf.id}
              style={`--shelf-accent: ${shelf.accent}; --shelf-tone: ${shelf.tone};`}
              aria-labelledby={`${shelf.id}-title`}
            >
              <div class="shelf-label">
                <span>
                  {copy.shelf} {shelfIndex + 1}
                </span>
                <h2 id={`${shelf.id}-title`}>{shelf.category}</h2>
                <p>
                  {shelf.posts.length} {copy.articleLabel}
                </p>
              </div>

              <div class="book-rail">
                {shelf.posts.map((post, postIndex) => (
                  <a
                    class={`book-card ${shelfIndex === 0 && postIndex === 0 ? 'is-featured' : ''}`}
                    href={getBlogPostUrl(lang, getSlugFromEntry(post))}
                    style={`--book-color: ${getBookTone(shelfIndex, postIndex)}; --book-height: ${Math.min(13.5, 8.75 + getReadMinutes(post.data.readTime) * 0.22)}rem; --book-delay: ${postIndex * 50}ms;`}
                    aria-label={`${copy.open}: ${post.data.title}`}
                    title={post.data.title}
                  >
                    <span class="book-edge" aria-hidden="true" />
                    <span class="book-spine">
                      <span class="book-title">
                        {lang === 'en'
                          ? getSpineTitleParts(post).map((word) => (
                              <span>{word}</span>
                            ))
                          : getSpineTitle(post)}
                      </span>
                      <span class="book-meta">{post.data.readTime}</span>
                    </span>
                    <span class="book-preview">
                      <span class="preview-kicker">
                        {post.data.category} /{' '}
                        {getFormatLabel(post.data.readTime)}
                      </span>
                      <strong>{post.data.title}</strong>
                      <span class="preview-description">
                        {post.data.description}
                      </span>
                      <span class="preview-tags">
                        {(post.data.tags ?? []).slice(0, 3).map((tag) => (
                          <em>{tag}</em>
                        ))}
                      </span>
                      <span class="preview-meta">
                        <span>
                          <Icon name="calendar" size={15} />{' '}
                          {formatDate(post.data.pubDate, lang)}
                        </span>
                        <span>
                          <Icon name="clock" size={15} /> {post.data.readTime}
                        </span>
                      </span>
                      <span class="preview-action">
                        {copy.open}
                        <Icon name="arrow-right" size={16} />
                      </span>
                    </span>
                  </a>
                ))}

                <div class="empty-cubby" aria-hidden="true">
                  <span class="empty-cubby-slots">
                    <i />
                    <i />
                    <i />
                  </span>
                  <span class="empty-cubby-note">{copy.empty}</span>
                </div>
              </div>
            </section>
          ))}
        </div>
      ) : (
        <div class="empty-library">
          <Icon name="library" size={36} />
          <p>{copy.empty}</p>
        </div>
      )
    }
  </section>
</div>

<script is:inline>
  const libraryRoot = document.querySelector('.spatial-library');
  const shelfLinks = Array.from(document.querySelectorAll('[data-shelf-link]'));
  const shelfSections = Array.from(
    document.querySelectorAll('[data-shelf-section]')
  );
  let manualShelfUntil = 0;

  const setActiveShelf = (shelfId) => {
    shelfLinks.forEach((link) => {
      const isActive = link.getAttribute('data-shelf-link') === shelfId;
      link.classList.toggle('is-active', isActive);
      if (isActive) {
        link.setAttribute('aria-current', 'location');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  };

  const scrollToShelf = (shelfId) => {
    const targetElement = document.getElementById(shelfId);
    if (!targetElement) return;

    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;
    targetElement.scrollIntoView({
      block: 'start',
      behavior: prefersReducedMotion ? 'auto' : 'smooth',
    });

    if (window.history?.replaceState) {
      window.history.replaceState(null, '', `#${shelfId}`);
    }
  };

  shelfLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      const target = link.getAttribute('data-shelf-link');
      if (!target) return;

      event.preventDefault();
      manualShelfUntil = Date.now() + 900;
      setActiveShelf(target);
      scrollToShelf(target);
    });
  });

  if (
    libraryRoot &&
    shelfSections.length > 0 &&
    'IntersectionObserver' in window
  ) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (Date.now() < manualShelfUntil) return;

        const visibleEntry = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        const shelfId = visibleEntry?.target.getAttribute('data-shelf-section');
        if (shelfId) setActiveShelf(shelfId);
      },
      {
        rootMargin: '-28% 0px -48% 0px',
        threshold: [0.2, 0.45, 0.7],
      }
    );

    shelfSections.forEach((section) => observer.observe(section));
  }
</script>

<style>
  .spatial-library {
    --library-ink: #0b1215;
    --library-panel: #111b1f;
    --library-line: rgba(205, 231, 225, 0.18);
    --library-text: #f6f0e5;
    --library-muted: #99aaa9;
    --library-wood: #6b4128;
    --library-wood-dark: #2b1b14;
    display: grid;
    grid-template-columns: 1fr;
    min-height: calc(100vh - 10rem);
    margin: -1.25rem auto 0;
    max-width: 108rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background:
      linear-gradient(120deg, rgba(86, 199, 201, 0.08), transparent 28rem),
      radial-gradient(
        circle at 85% 12%,
        rgba(217, 155, 102, 0.12),
        transparent 24rem
      ),
      var(--library-ink);
    box-shadow: 0 2rem 5rem rgba(15, 23, 42, 0.22);
    color: var(--library-text);
    overflow: hidden;
  }

  .library-sidebar {
    position: relative;
    display: grid;
    grid-template-columns: auto auto minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    padding: 0.85rem clamp(1rem, 2vw, 1.5rem);
    border-bottom: 1px solid var(--library-line);
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.045), transparent 32rem),
      rgba(5, 12, 15, 0.84);
  }

  .sidebar-mark,
  .shelf-nav-link,
  .reading-path-link,
  .preview-meta,
  .preview-action {
    display: inline-flex;
    align-items: center;
  }

  .sidebar-mark {
    gap: 0.75rem;
    font-family: Merriweather, serif;
    font-size: 0.96rem;
    font-weight: 700;
  }

  .mark-glyph {
    display: inline-grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid rgba(246, 240, 229, 0.22);
    background: rgba(246, 240, 229, 0.07);
  }

  .sidebar-title p,
  .library-toolbar p,
  .shelf-label span,
  .shelf-label p {
    color: var(--library-muted);
  }

  .sidebar-title p {
    display: none;
    margin: 0;
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .sidebar-title strong {
    display: inline;
    font-family: Merriweather, serif;
    margin-right: 0.28rem;
    font-size: 1.1rem;
    line-height: 1;
  }

  .sidebar-title span {
    color: #6ad4d5;
    font-size: 0.8rem;
  }

  .shelf-nav {
    display: flex;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 0.45rem;
    grid-column: 3;
  }

  .shelf-nav-link {
    min-height: 2.25rem;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0 0.65rem;
    border: 1px solid transparent;
    color: #d5dfdb;
    font-size: 0.78rem;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .shelf-nav-link span {
    flex: 0 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .shelf-nav-link em {
    color: var(--library-muted);
    font-style: normal;
  }

  .shelf-nav-link:hover,
  .shelf-nav-link:focus-visible,
  .shelf-nav-link.is-active {
    border-color: rgba(106, 212, 213, 0.4);
    background: rgba(106, 212, 213, 0.1);
    color: #f6f0e5;
    transform: translateY(-0.08rem);
  }

  .reading-paths {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.85rem;
    padding: 0.45rem;
    border: 1px solid rgba(205, 231, 225, 0.13);
    background: rgba(246, 240, 229, 0.035);
  }

  .reading-paths > span {
    flex: 0 0 auto;
    padding: 0 0.45rem;
    color: rgba(246, 240, 229, 0.46);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .reading-path-link {
    min-width: 0;
    gap: 0.38rem;
    min-height: 2rem;
    padding: 0 0.55rem;
    border: 1px solid transparent;
    color: #d5dfdb;
    font-size: 0.72rem;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }

  .reading-path-link em {
    color: #6ad4d5;
    font-style: normal;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .reading-path-link strong {
    min-width: 0;
    overflow: hidden;
    color: rgba(246, 240, 229, 0.82);
    font-weight: 700;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .reading-path-link:hover,
  .reading-path-link:focus-visible {
    border-color: rgba(106, 212, 213, 0.36);
    background: rgba(106, 212, 213, 0.1);
    transform: translateY(-0.08rem);
  }

  .library-stage {
    min-width: 0;
    scroll-margin-top: 6.5rem;
    padding: 0.85rem clamp(0.85rem, 2vw, 1.5rem) 1.5rem;
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.04), transparent 18rem),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.018) 0 1px,
        transparent 1px 5rem
      );
  }

  .library-toolbar {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .library-toolbar h1 {
    margin: 0;
    font-family: Merriweather, serif;
    font-size: clamp(1.35rem, 2.1vw, 2.2rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .library-toolbar p {
    display: none;
  }

  .shelf-wall {
    display: grid;
    gap: 0.9rem;
    perspective: 1600px;
  }

  .shelf-bay {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(6.5rem, 8.5rem) minmax(0, 1fr);
    min-height: clamp(17rem, 32vh, 21rem);
    scroll-margin-top: 6.5rem;
    border: 1px solid rgba(223, 190, 151, 0.2);
    background:
      linear-gradient(90deg, rgba(8, 12, 13, 0.35), transparent 26%),
      linear-gradient(180deg, rgba(125, 77, 46, 0.42), rgba(42, 26, 18, 0.7)),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.04) 0 1px,
        transparent 1px 2.4rem
      );
    box-shadow:
      inset 0 1rem 2rem rgba(0, 0, 0, 0.28),
      0 1.5rem 3rem rgba(0, 0, 0, 0.16);
    transform: rotateX(0.6deg);
    transform-style: preserve-3d;
  }

  .shelf-bay::before,
  .shelf-bay::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 0.72rem;
    background:
      linear-gradient(180deg, rgba(245, 186, 128, 0.5), rgba(80, 45, 28, 0.88)),
      var(--library-wood);
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.35);
    z-index: 4;
  }

  .shelf-bay::before {
    top: 0;
  }

  .shelf-bay::after {
    bottom: 0;
  }

  .shelf-bay:has(.book-card:hover),
  .shelf-bay:has(.book-card:focus-visible),
  .shelf-bay:has(.book-card.is-featured) {
    z-index: 12;
  }

  .shelf-label {
    position: relative;
    z-index: 5;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin: 1.5rem 1rem;
    padding: 0.9rem;
    border: 1px solid rgba(246, 240, 229, 0.14);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 55%),
      color-mix(in srgb, var(--shelf-tone), #0b1215 26%);
    box-shadow: 0.5rem 0.7rem 1.2rem rgba(0, 0, 0, 0.25);
  }

  .shelf-label span {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .shelf-label h2 {
    margin: 0.45rem 0 0.8rem;
    color: #f6f0e5;
    font-family: Merriweather, serif;
    font-size: clamp(1.1rem, 1.6vw, 1.5rem);
    line-height: 1.12;
  }

  .shelf-label p {
    margin: 0;
    font-size: 0.76rem;
  }

  .book-rail {
    position: relative;
    display: flex;
    align-items: end;
    gap: 0.42rem;
    min-width: 0;
    padding: 2.1rem 1.25rem 1.25rem 0.25rem;
    transform-style: preserve-3d;
  }

  .book-card {
    position: relative;
    z-index: 8;
    display: block;
    flex: 0 0 clamp(3rem, 4.8vw, 4.15rem);
    height: var(--book-height);
    min-height: 8.75rem;
    color: #f6f0e5;
    outline-offset: 5px;
    text-decoration: none;
    transform: translateZ(0) rotateY(-4deg);
    transform-origin: bottom left;
    transition:
      transform 220ms ease,
      filter 220ms ease,
      z-index 0ms linear 80ms;
    animation: bookIn 460ms ease both;
    animation-delay: var(--book-delay);
  }

  .book-card:hover,
  .book-card:focus-visible,
  .book-card:focus-within,
  .book-card.is-featured {
    z-index: 30;
    filter: saturate(1.08) brightness(1.08);
    transform: translate3d(0.45rem, -0.4rem, 4rem) rotateY(-16deg);
  }

  .book-spine {
    position: absolute;
