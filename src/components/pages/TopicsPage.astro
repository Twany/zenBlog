---
import Icon from '../Icon.astro';
import SectionHeading from '../SectionHeading.astro';
import { formatDate } from '../../utils/date';
import { getTopicLatestHref, getTopicSummaries } from '../../utils/topics';
import type { BlogEntry } from '../../utils/blog';
import type { Locale } from '../../utils/i18n';

interface Props {
  lang: Locale;
  posts: BlogEntry[];
}

const { lang, posts } = Astro.props as Props;
const topics = getTopicSummaries(posts, lang).slice(0, 12);
const copy =
  lang === 'en'
    ? {
        title: 'Topics',
        intro:
          'A topic map for the archive: AI workflow, design, product thinking, publishing, and the engineering details behind them.',
        latest: 'Latest',
        articles: 'articles',
        article: 'article',
        browse: 'Browse topic',
        readLatest: 'Read latest',
      }
    : {
        title: '专题',
        intro:
          '把归档按主题重新组织：AI 工作流、设计、产品思考、发布系统，以及背后的工程细节。',
        latest: '最新',
        articles: '篇文章',
        article: '篇文章',
        browse: '浏览专题',
        readLatest: '阅读最新',
      };
---

<div class="mx-auto max-w-7xl px-6">
  <div class="mb-12 max-w-3xl">
    <SectionHeading title={copy.title} as="h1" class="mb-6" />
    <p class="text-base leading-8 text-slate-600 md:text-lg">{copy.intro}</p>
  </div>

  <div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
    {
      topics.map((topic, index) => (
        <article class="group flex min-h-[19rem] flex-col border-t border-slate-200 pt-5 transition-colors hover:border-brand-cyan">
          <div class="mb-8 flex items-start justify-between gap-4">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-cyan">
                {topic.kind}
              </span>
              <h2 class="mt-3 font-serif text-3xl font-normal leading-tight text-brand-dark text-balance">
                {topic.name}
              </h2>
            </div>
            <span class="font-mono text-xs text-slate-400">
              {String(index + 1).padStart(2, '0')}
            </span>
          </div>

          <p class="mb-8 text-sm leading-7 text-slate-600">
            {topic.description}
          </p>

          <div class="mt-auto space-y-5">
            <div class="border-t border-slate-100 pt-4">
              <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">
                {copy.latest} / {topic.count}{' '}
                {topic.count === 1 ? copy.article : copy.articles}
              </span>
              <a
                href={getTopicLatestHref(lang, topic)}
                class="mt-2 block font-serif text-lg leading-snug text-brand-dark transition-colors group-hover:text-brand-cyan"
              >
                {topic.latestPost.data.title}
              </a>
              <span class="mt-2 block text-xs font-semibold uppercase tracking-wider text-slate-500">
                {formatDate(topic.latestPost.data.pubDate, lang)}
              </span>
            </div>

            <div class="flex flex-wrap gap-3">
              <a
                href={topic.href}
                class="inline-flex min-h-11 items-center gap-2 border border-slate-200 px-3 text-xs font-semibold uppercase tracking-widest text-slate-600 transition-colors hover:border-brand-cyan hover:text-brand-cyan"
              >
                {copy.browse}
                <Icon name="arrow-right" size={14} />
              </a>
              <a
                href={getTopicLatestHref(lang, topic)}
                class="inline-flex min-h-11 items-center gap-2 px-1 text-xs font-semibold uppercase tracking-widest text-brand-cyan transition-colors hover:text-brand-dark"
              >
                {copy.readLatest}
              </a>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</div>
