---
import Icon from '../Icon.astro';
import { uiLabels } from '../../data/uiLabels';
import { formatDate } from '../../utils/date';
import {
  getBlogIndexUrl,
  getBlogPostUrl,
  getSlugFromEntry,
} from '../../utils/blog';
import { SITE } from '../../data/site';
import type { BlogEntry } from '../../utils/blog';
import type { Locale } from '../../utils/i18n';

interface Props {
  entry: BlogEntry;
  lang: Locale;
  posts: BlogEntry[];
}

const { entry, lang, posts } = Astro.props as Props;
const { Content, headings } = await entry.render();
const tocItems = headings.filter(
  (heading) => heading.depth === 2 || heading.depth === 3
);

const currentIndex = posts.findIndex((post) => post.id === entry.id);
const prevPost =
  currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : null;

const entryTags = entry.data.tags ?? [];
const relatedPosts = posts
  .filter((post) => post.id !== entry.id)
  .map((post) => {
    const sharedTags = (post.data.tags ?? []).filter((tag) =>
      entryTags.includes(tag)
    );
    const categoryScore = post.data.category === entry.data.category ? 1 : 0;
    const templateScore = post.data.template === entry.data.template ? 1 : 0;
    return {
      post,
      sharedTags,
      sameCategory: categoryScore > 0,
      sameTemplate: templateScore > 0,
      score: sharedTags.length * 2 + categoryScore + templateScore,
    };
  })
  .filter((item) => item.score > 0)
  .sort(
    (a, b) =>
      b.score - a.score ||
      b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf()
  )
  .slice(0, 3);
const continueReadingCopy =
  lang === 'en'
    ? {
        title: 'Continue reading',
        description: 'Move to the neighboring essay in the archive.',
      }
    : {
        title: '继续阅读',
        description: '按归档顺序读上一篇或下一篇。',
      };
const shareCopy =
  lang === 'en'
    ? {
        title: 'Share or save',
        description:
          'Keep this article nearby, or send it to someone working through the same problem.',
        nativeShare: 'Share',
        copyLink: 'Copy link',
        copied: 'Link copied.',
        copyFailed: 'Copy failed. Select the URL manually.',
      }
    : {
        title: '分享或收藏',
        description: '把这篇文章留在手边，或发给正在处理同类问题的人。',
        nativeShare: '分享',
        copyLink: '复制链接',
        copied: '链接已复制。',
        copyFailed: '复制失败，请手动复制地址。',
      };
const summaryCopy =
  lang === 'en'
    ? {
        title: 'Summary',
        description: entry.data.description,
      }
    : {
        title: '摘要',
        description: entry.data.description,
      };
const absolutePostUrl = new URL(
  getBlogPostUrl(lang, getSlugFromEntry(entry)),
  SITE.url
).toString();
---

<div
  class="fixed top-0 left-0 h-1 bg-brand-cyan z-[60] transition-all duration-150"
  data-reading-progress
>
</div>

<div class="mx-auto max-w-6xl px-5 md:px-6 animate-fade-in pb-20">
  <a
    href={getBlogIndexUrl(lang)}
    class="group mb-6 flex min-h-11 items-center gap-2 text-sm font-medium text-slate-500 transition-colors hover:text-brand-cyan md:mb-8"
  >
    <div
      class="p-1 border border-gray-200 group-hover:border-brand-cyan transition-colors"
    >
      <Icon name="arrow-left" size={16} />
    </div>
    {uiLabels.common.backToBlog[lang]}
  </a>

  <header
    class="mb-10 md:mb-12 border-b border-slate-200 pb-10 md:pb-12 max-w-4xl"
  >
    <div
      class="mb-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-medium text-slate-500 md:mb-6"
    >
      <span class="flex items-center gap-1"
        ><Icon name="calendar" size={14} />{
          formatDate(entry.data.pubDate, lang)
        }</span
      >
      <span class="flex items-center gap-1"
        ><Icon name="clock" size={14} />{entry.data.readTime}</span
      >
    </div>

    <h1
      class="font-serif font-normal text-3xl md:text-5xl lg:text-6xl text-brand-dark leading-tight mb-6 text-balance"
    >
      {entry.data.title}
    </h1>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 relative">
    <div class="lg:col-span-8 xl:col-span-7">
      {
        tocItems.length ? (
          <div class="lg:hidden mb-8 border-y border-gray-200 bg-white">
            <button
              type="button"
              class="min-h-12 w-full flex items-center justify-between py-3 bg-transparent font-sans font-semibold text-brand-dark"
              data-toc-toggle
              aria-expanded="false"
            >
              <span class="flex items-center gap-2 text-sm">
                <Icon name="list" size={18} />{' '}
                {uiLabels.blog.tableOfContents[lang]}
              </span>
              <span data-toc-icon>
                <Icon name="chevron-down" size={18} />
              </span>
            </button>
            <nav class="pb-4 space-y-1 hidden" data-toc-panel>
              {tocItems.map((item) => (
                <button
                  type="button"
                  class={`block min-h-11 text-left text-sm py-2 transition-colors w-full ${
                    item.depth === 3 ? 'pl-4' : ''
                  } text-slate-600`}
                  data-toc-link={item.slug}
                >
                  {item.text}
                </button>
              ))}
            </nav>
          </div>
        ) : null
      }

      <section class="mb-8 max-w-[68ch] border border-slate-200 p-5 md:p-6">
        <h2 class="font-sans text-sm font-semibold text-brand-dark">
          {summaryCopy.title}
        </h2>
        <p class="mt-3 font-sans text-base leading-7 text-slate-600">
          {summaryCopy.description}
        </p>
      </section>

      <div class="prose prose-slate max-w-[68ch] font-sans text-gray-700">
        <Content />
      </div>

      <section
        class="mt-16 border-y border-slate-200 py-6 md:mt-20"
        data-article-actions
        data-share-url={absolutePostUrl}
        data-share-title={entry.data.title}
      >
        <div
          class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between"
        >
          <div class="max-w-xl">
            <h3
              class="flex items-center gap-2 font-sans text-sm font-semibold text-brand-dark"
            >
              <Icon name="sparkles" size={16} />
              {shareCopy.title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-slate-500">
              {shareCopy.description}
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <button
              type="button"
              class="inline-flex min-h-11 items-center gap-2 border-b border-slate-200 text-sm font-medium text-slate-600 transition-colors hover:border-brand-cyan hover:text-brand-cyan"
              data-native-share
            >
              <Icon name="share-2" size={15} />
              {shareCopy.nativeShare}
            </button>
            <button
              type="button"
              class="inline-flex min-h-11 items-center gap-2 border-b border-slate-200 text-sm font-medium text-slate-600 transition-colors hover:border-brand-cyan hover:text-brand-cyan"
              data-copy-link
            >
              <Icon name="link" size={15} />
              {shareCopy.copyLink}
            </button>
          </div>
        </div>

        <p
          class="sr-only mt-4 text-sm text-slate-500"
          aria-live="polite"
          data-share-status
        >
          {shareCopy.copied}
        </p>
      </section>

      {
        prevPost || nextPost ? (
          <section class="mt-10 md:mt-12 border-t border-gray-200 pt-7">
            <div class="mb-5">
              <h3 class="font-sans text-sm font-semibold text-brand-dark">
                {continueReadingCopy.title}
              </h3>
              <p class="mt-2 text-sm text-slate-500">
                {continueReadingCopy.description}
              </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {prevPost ? (
                <a
                  href={getBlogPostUrl(lang, getSlugFromEntry(prevPost))}
                  class="group border-t border-gray-200 py-5 md:p-6 text-left transition-colors bg-white hover:bg-white"
                >
                  <span class="mb-2 block text-sm font-medium text-slate-500 group-hover:text-brand-cyan">
                    {uiLabels.blog.previousArticle[lang]}
                  </span>
                  <span class="font-serif text-base md:text-lg text-brand-dark group-hover:text-brand-cyan transition-colors">
                    {prevPost.data.title}
                  </span>
                </a>
              ) : (
                <div />
              )}

              {nextPost ? (
                <a
                  href={getBlogPostUrl(lang, getSlugFromEntry(nextPost))}
                  class="group border-t border-gray-200 py-5 md:p-6 text-left md:text-right transition-colors bg-white hover:bg-white"
                >
                  <span class="mb-2 block text-sm font-medium text-slate-500 group-hover:text-brand-cyan">
                    {uiLabels.blog.nextArticle[lang]}
                  </span>
                  <span class="font-serif text-base md:text-lg text-brand-dark group-hover:text-brand-cyan transition-colors">
                    {nextPost.data.title}
                  </span>
                </a>
              ) : (
                <div />
              )}
            </div>
          </section>
        ) : null
      }

      {
        relatedPosts.length ? (
          <div class="mt-20">
            <h3 class="mb-8 border-b border-gray-200 pb-4 font-sans text-sm font-semibold text-brand-dark">
              {uiLabels.blog.relatedPosts[lang]}
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              {relatedPosts.map(({ post }) => (
                <a
                  href={getBlogPostUrl(lang, getSlugFromEntry(post))}
                  class="group block border border-slate-200 p-5 transition-colors hover:border-brand-cyan"
                >
                  <h4 class="font-serif text-xl text-brand-dark group-hover:text-brand-cyan transition-colors mb-2">
                    {post.data.title}
                  </h4>
                  <p class="text-sm font-medium text-slate-500">
                    {formatDate(post.data.pubDate, lang)}
                  </p>
                </a>
              ))}
            </div>
          </div>
        ) : null
      }
    </div>

    <aside
      class="hidden lg:block lg:col-span-4 xl:col-span-4 xl:col-start-9 relative"
    >
      <div class="sticky top-32">
        {
          tocItems.length ? (
            <div>
              <h4 class="mb-6 flex items-center gap-2 font-sans text-sm font-semibold text-slate-500">
                <Icon name="list" size={16} />{' '}
                {uiLabels.blog.tableOfContents[lang]}
              </h4>
              <nav class="relative border-l-2 border-gray-100">
                {tocItems.map((item) => (
                  <button
                    type="button"
                    class={`block min-h-11 text-left text-sm py-2 pl-4 -ml-[2px] border-l-2 transition-all w-full hover:text-brand-dark ${
                      item.depth === 3 ? 'ml-4' : ''
                    } border-transparent text-slate-600`}
                    data-toc-link={item.slug}
                  >
                    {item.text}
                  </button>
                ))}
              </nav>
            </div>
          ) : null
        }
      </div>
    </aside>
  </div>
</div>

<script is:inline>
  const articleActions = document.querySelector('[data-article-actions]');
  const nativeShareButton = articleActions?.querySelector(
    '[data-native-share]'
  );
  const copyLinkButton = articleActions?.querySelector('[data-copy-link]');
  const shareStatus = articleActions?.querySelector('[data-share-status]');

  const setShareStatus = (message) => {
    if (!shareStatus) return;
    shareStatus.classList.remove('sr-only');
    shareStatus.textContent = message;
  };

  nativeShareButton?.addEventListener('click', async () => {
    const url =
      articleActions?.getAttribute('data-share-url') || window.location.href;
    const title =
      articleActions?.getAttribute('data-share-title') || document.title;

    if (navigator.share) {
      await navigator.share({ title, url });
      return;
    }

    try {
      await navigator.clipboard.writeText(url);
      setShareStatus(
        document.documentElement.lang.startsWith('zh')
          ? '链接已复制。'
          : 'Link copied.'
      );
    } catch {
      setShareStatus(
        document.documentElement.lang.startsWith('zh')
          ? '复制失败，请手动复制地址。'
          : 'Copy failed. Select the URL manually.'
      );
    }
  });

  copyLinkButton?.addEventListener('click', async () => {
    const url =
      articleActions?.getAttribute('data-share-url') || window.location.href;
    try {
      await navigator.clipboard.writeText(url);
      setShareStatus(
        document.documentElement.lang.startsWith('zh')
          ? '链接已复制。'
          : 'Link copied.'
      );
    } catch {
      setShareStatus(
        document.documentElement.lang.startsWith('zh')
          ? '复制失败，请手动复制地址。'
          : 'Copy failed. Select the URL manually.'
      );
    }
  });
</script>

<script>
  import '../../scripts/blog-post';
</script>
