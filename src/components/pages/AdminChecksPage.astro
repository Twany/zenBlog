---
import Icon from '../Icon.astro';

type CheckRow = {
  title: string;
  slug: string;
  lang: 'en' | 'zh';
  url: string;
  translationKey: string;
  draft: boolean;
  template: string;
  tagCount: number;
  descriptionOk: boolean;
  socialSummaryOk: boolean;
  ogOk: boolean;
  paired: boolean;
  issues: string[];
};

interface Props {
  rows: CheckRow[];
}

const { rows } = Astro.props as Props;
const readyRows = rows.filter((row) => row.issues.length === 0);
const issueRows = rows.filter((row) => row.issues.length > 0);
const drafts = rows.filter((row) => row.draft);
const copy = {
  title: 'Publish Checks',
  intro:
    'A static preflight view for the content system: pairing, metadata, templates, tags, social summaries, and OG image assets.',
  openCms: 'Open CMS',
  liveSite: 'Live site',
  ready: 'ready',
  issues: 'issues',
  drafts: 'drafts',
  total: 'posts',
  allClear: 'All published posts pass the current checks.',
};

const statItems = [
  { label: copy.total, value: rows.length },
  { label: copy.ready, value: readyRows.length },
  { label: copy.issues, value: issueRows.length },
  { label: copy.drafts, value: drafts.length },
];
---

<div class="mx-auto max-w-7xl px-6 pb-20">
  <header
    class="mb-12 grid grid-cols-1 gap-10 border-b border-slate-200 pb-12 lg:grid-cols-12"
  >
    <div class="lg:col-span-8">
      <p
        class="mb-5 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-brand-cyan"
      >
        Admin
      </p>
      <h1
        class="font-serif text-4xl font-normal leading-tight text-brand-dark md:text-6xl"
      >
        {copy.title}
      </h1>
      <p class="mt-6 max-w-3xl text-base leading-8 text-slate-600">
        {copy.intro}
      </p>
    </div>

    <div class="lg:col-span-4">
      <div class="grid grid-cols-2 gap-4 border-y border-slate-200 py-5">
        {
          statItems.map((item) => (
            <div>
              <div class="font-serif text-3xl text-brand-dark">
                {item.value}
              </div>
              <div class="mt-1 text-xs font-semibold uppercase tracking-widest text-slate-500">
                {item.label}
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/admin/cms/"
          class="inline-flex min-h-11 items-center gap-2 border border-slate-200 px-3 text-xs font-semibold uppercase tracking-widest text-slate-600 transition-colors hover:border-brand-cyan hover:text-brand-cyan"
        >
          {copy.openCms}
          <Icon name="arrow-right" size={14} />
        </a>
        <a
          href="/"
          class="inline-flex min-h-11 items-center gap-2 px-1 text-xs font-semibold uppercase tracking-widest text-brand-cyan transition-colors hover:text-brand-dark"
        >
          {copy.liveSite}
        </a>
      </div>
    </div>
  </header>

  {
    issueRows.length ? (
      <section class="mb-12">
        <h2 class="mb-6 font-sans text-sm font-semibold uppercase tracking-widest text-brand-dark">
          Needs attention
        </h2>
        <div class="space-y-5">
          {issueRows.map((row) => (
            <article class="border-t border-slate-200 pt-5">
              <div class="grid grid-cols-1 gap-5 lg:grid-cols-12">
                <div class="lg:col-span-5">
                  <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-cyan">
                    {row.lang} / {row.template}
                  </span>
                  <h3 class="mt-3 font-serif text-2xl leading-tight text-brand-dark">
                    {row.title}
                  </h3>
                  <a
                    href={row.url}
                    class="mt-3 inline-flex text-xs font-semibold uppercase tracking-widest text-slate-500 transition-colors hover:text-brand-cyan"
                  >
                    {row.slug}
                  </a>
                </div>
                <div class="lg:col-span-7">
                  <div class="flex flex-wrap gap-2">
                    {row.issues.map((issue) => (
                      <span class="border border-slate-200 px-2.5 py-2 text-[11px] font-semibold uppercase tracking-wider text-slate-600">
                        {issue}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : (
      <p class="mb-12 border-y border-slate-200 py-6 text-sm text-slate-600">
        {copy.allClear}
      </p>
    )
  }

  <section>
    <h2
      class="mb-6 font-sans text-sm font-semibold uppercase tracking-widest text-brand-dark"
    >
      All posts
    </h2>
    <div class="overflow-x-auto border-t border-slate-200">
      <table class="min-w-full border-collapse text-left text-sm">
        <thead>
          <tr
            class="border-b border-slate-200 text-xs font-semibold uppercase tracking-widest text-slate-500"
          >
            <th class="py-4 pr-5 font-semibold">Post</th>
            <th class="py-4 pr-5 font-semibold">Lang</th>
            <th class="py-4 pr-5 font-semibold">Template</th>
            <th class="py-4 pr-5 font-semibold">Tags</th>
            <th class="py-4 pr-5 font-semibold">Pair</th>
            <th class="py-4 pr-5 font-semibold">OG</th>
            <th class="py-4 pr-5 font-semibold">Summary</th>
            <th class="py-4 pr-5 font-semibold">State</th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map((row) => (
              <tr class="border-b border-slate-100 align-top">
                <td class="max-w-sm py-4 pr-5">
                  <a
                    href={row.url}
                    class="font-serif text-base leading-snug text-brand-dark transition-colors hover:text-brand-cyan"
                  >
                    {row.title}
                  </a>
                  <div class="mt-1 font-mono text-[11px] text-slate-500">
                    {row.translationKey}
                  </div>
                </td>
                <td class="py-4 pr-5 font-mono text-xs uppercase text-slate-600">
                  {row.lang}
                </td>
                <td class="py-4 pr-5 text-xs font-semibold uppercase tracking-wider text-slate-600">
                  {row.template}
                </td>
                <td class="py-4 pr-5 text-slate-600">{row.tagCount}</td>
                <td class="py-4 pr-5 text-slate-600">
                  {row.paired ? 'ok' : 'missing'}
                </td>
                <td class="py-4 pr-5 text-slate-600">
                  {row.ogOk ? 'ok' : 'missing'}
                </td>
                <td class="py-4 pr-5 text-slate-600">
                  {row.socialSummaryOk ? 'ok' : 'missing'}
                </td>
                <td class="py-4 pr-5">
                  <span
                    class={`text-xs font-semibold uppercase tracking-widest ${
                      row.issues.length ? 'text-slate-700' : 'text-brand-cyan'
                    }`}
                  >
                    {row.issues.length ? `${row.issues.length} issue` : 'ready'}
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</div>
