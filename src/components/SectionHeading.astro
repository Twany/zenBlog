---
interface Props {
  title: string;
  class?: string;
  as?: 'h1' | 'h2' | 'h3';
}

const { title, class: className = '', as = 'h2' } = Astro.props as Props;
const Tag = as;
---
<div class={`mb-10 ${className}`}>
  <Tag class="font-serif text-4xl lg:text-5xl text-brand-dark font-normal border-b border-gray-200 pb-4 inline-block w-full text-balance">
    {title}
  </Tag>
</div>
