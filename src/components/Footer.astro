---
import { uiLabels } from '../data/uiLabels';
import { getLocalizedPath, type Locale } from '../utils/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white text-slate-600">
  <div
    class="mx-auto flex max-w-7xl flex-col gap-6 px-5 py-8 md:flex-row md:items-end md:justify-between md:px-6"
  >
    <div class="max-w-xl">
      <a
        href={getLocalizedPath('/', lang)}
        class="font-serif text-xl font-normal text-brand-dark transition-colors hover:text-brand-cyan"
      >
        {uiLabels.nav.home[lang]}
      </a>
      <p class="mt-3 max-w-lg font-serif text-sm leading-6 text-slate-500">
        {uiLabels.footer.aboutBlurb[lang]}
      </p>
    </div>

    <nav
      class="flex flex-col gap-3 text-sm font-medium md:items-end"
      aria-label="Footer navigation"
    >
      <a
        href={getLocalizedPath('/contact/', lang)}
        class="text-brand-cyan transition-colors hover:text-brand-dark"
      >
        {uiLabels.footer.sayHello[lang]} -&gt;
      </a>
      <p class="text-xs font-normal text-slate-500">
        &copy; {year} Twany's Blog.
      </p>
    </nav>
  </div>
</footer>
