---
import { uiLabels } from '../data/uiLabels';
import { getLocalizedPath, type Locale } from '../utils/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props as Props;
const year = new Date().getFullYear();

const footerLinks = [
  { label: uiLabels.nav.blog[lang], path: '/blog/' },
  { label: uiLabels.nav.topics[lang], path: '/topics/' },
  { label: uiLabels.nav.library[lang], path: '/library/' },
  { label: uiLabels.nav.notes[lang], path: '/notes/' },
  { label: uiLabels.nav.experiments[lang], path: '/experiments/' },
  { label: uiLabels.nav.about[lang], path: '/about/' },
];
---

<footer class="border-t border-slate-200 bg-white text-slate-600">
  <div class="mx-auto max-w-7xl px-5 py-8 md:px-6 lg:py-10">
    <div
      class="flex flex-col gap-7 lg:flex-row lg:items-start lg:justify-between"
    >
      <div class="max-w-xl">
        <a
          href={getLocalizedPath('/', lang)}
          class="font-display text-xl font-bold uppercase tracking-[0.05em] text-brand-dark transition-colors hover:text-brand-cyan"
        >
          {uiLabels.nav.home[lang]}
        </a>
        <p class="mt-3 max-w-lg font-serif text-sm leading-6 text-slate-500">
          {uiLabels.footer.aboutBlurb[lang]}
        </p>
      </div>

      <nav
        class="flex max-w-2xl flex-wrap gap-x-5 gap-y-3 text-xs font-bold uppercase tracking-[0.16em] text-slate-500"
        aria-label="Footer navigation"
      >
        {
          footerLinks.map((link) => (
            <a
              href={getLocalizedPath(link.path, lang)}
              class="transition-colors hover:text-brand-cyan"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div
      class="mt-7 flex flex-col gap-4 border-t border-slate-200 pt-5 text-xs text-slate-500 md:flex-row md:items-center md:justify-between"
    >
      <p>&copy; {year} Twany's Blog.</p>
      <a
        href={getLocalizedPath('/contact/', lang)}
        class="inline-flex w-fit items-center gap-2 font-bold uppercase tracking-[0.16em] text-brand-cyan transition-colors hover:text-brand-dark"
      >
        {uiLabels.footer.sayHello[lang]}
        <span aria-hidden="true">-&gt;</span>
      </a>
    </div>
  </div>
</footer>
