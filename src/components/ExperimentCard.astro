---
import type { Experiment } from '../types';
import type { Locale } from '../utils/i18n';

interface Props {
  experiment: Experiment;
  lang: Locale;
}

const { experiment, lang } = Astro.props as Props;

const colorMap = {
  cyan: 'border-brand-cyan',
  blue: 'border-brand-dark',
  lime: 'border-lime-500',
  orange: 'border-orange-500',
} as const;
---
<a
  href={`#experiment-${experiment.id}`}
  class={`group flex min-h-56 flex-col justify-between border-t-2 bg-white/40 p-5 transition-colors hover:bg-white ${
    colorMap[experiment.color]
  }`}
>
  <div class="font-serif text-2xl font-normal leading-tight text-brand-dark group-hover:text-brand-cyan">
    {experiment.title[lang]}
  </div>

  <div class="font-sans text-sm leading-relaxed text-slate-600">
    {experiment.description[lang]}
  </div>
</a>
